# ============================================
# .gitignore — MERN Blog Project
# ============================================

# DEPENDENCIES
node_modules/
backend/node_modules/
frontend/node_modules/

# BUILD OUTPUT
frontend/dist/
dist/
build/

# ENVIRONMENT VARIABLES (ignore .env, keep .env.example)
.env
backend/.env
frontend/.env

# LOGS
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# UPLOADS
backend/uploads/*
!backend/uploads/.gitkeep

# OS FILES
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo

# EDITOR / IDE
.vscode/*
!.vscode/extensions.json
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# SCRIPTS
script.ps1

# MISC
*.local
.env.local
.env.production
.env.development

