# ============================================
# FILE: .env
# PURPOSE: Environment variables for backend server
# DESCRIPTION: Stores sensitive configuration like
#              database URI, JWT secret, and port number
# ============================================

# MongoDB connection string
# This tells Mongoose where to find our database
# "mern-blog" is the name of our database
MONGO_URI=mongodb://localhost:27017/mern-blog

# JWT Secret Key
# Used to sign and verify JSON Web Tokens
# In production, use a long random string
JWT_SECRET=mernblog_a7k9x2p4q8w1e6r3t5y0u_i9o3p5l7k2j4h6g8f

# Server Port
# The port where our Express server will listen
PORT=5000


